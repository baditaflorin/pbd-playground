{
  "name": "pbd-playground",
  "version": "0.1.0",
  "description": "A tactile WebGPU sandbox for dragging, tearing, and listening to real-time soft-body physics in the browser.",
  "type": "module",
  "private": false,
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/baditaflorin/pbd-playground.git"
  },
  "homepage": "https://baditaflorin.github.io/pbd-playground/",
  "scripts": {
    "dev": "vite --host 127.0.0.1",
    "build": "npm run build:wasm && npm run typecheck && npm run clean:pages && vite build && node scripts/write-404.mjs",
    "build:wasm": "bash scripts/build-wasm.sh",
    "clean:pages": "node scripts/clean-pages.mjs",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src tests vite.config.ts vitest.config.ts playwright.config.ts",
    "fmt": "prettier --write .",
    "fmt:check": "prettier --check .",
    "test": "vitest run",
    "test:watch": "vitest",
    "smoke": "bash scripts/smoke.sh",
    "preview:pages": "vite preview --host 127.0.0.1 --port 4173 --strictPort",
    "pages-preview": "npm run build && npm run preview:pages",
    "audit": "npm audit --audit-level=high"
  },
  "dependencies": {
    "lucide": "^0.468.0",
    "three": "^0.171.0",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@eslint/js": "^9.17.0",
    "@playwright/test": "^1.49.1",
    "@types/node": "^22.10.5",
    "@types/three": "^0.184.1",
    "eslint": "^9.17.0",
    "prettier": "^3.4.2",
    "sirv-cli": "^2.0.2",
    "typescript": "^5.7.2",
    "typescript-eslint": "^8.19.0",
    "vite": "^6.0.6",
    "vitest": "^2.1.8"
  },
  "engines": {
    "node": ">=22"
  }
}
